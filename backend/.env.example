# =====================================================================
# 本機開發環境變數樣板
# 1. 複製此檔為 backend/.env
# 2. 填入您自己的 Google API 金鑰並修改 DB / Redis 連線資訊
# 3. .env 不會被 git 追蹤（請見 .gitignore）
# =====================================================================

# --- Database (PostgreSQL) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mydatabase
# 若有設定 DATABASE_URL 會直接覆蓋上面 POSTGRES_* 組成的連線字串
# DATABASE_URL=postgresql://user:password@localhost:5432/mydatabase

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Redis (Celery broker + WebSocket pub/sub) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Celery ---
CELERY_TIMEZONE=Asia/Taipei
CELERY_RESULT_EXPIRES=86400

# --- App ---
TEMP_UPLOADS_DIR=temp_uploads

# --- VAD 除錯（可選）---
# 設為 true 時，VAD 切割產物會複製到 vad_artifacts/ 供本機试听檢查
# VAD_KEEP_ARTIFACTS=true
# VAD_ARTIFACTS_DIR=vad_artifacts

# --- Transcription tuning（可選，留空使用預設值） ---
# 單檔轉錄的最大可接受時長（秒）；超過此值且轉錄失敗時，會嘗試 VAD 分割重試
# TRANSCRIPTION_MAX_DURATION_SECONDS=180
# Batch / Flex 推論的費用折扣率（0.5 表示原價 50%）
# BATCH_COST_DISCOUNT=0.5
# FLEX_COST_DISCOUNT=0.5
# 語音佔比 >= 此閾值時跳過 VAD 預處理（0.8 = 空白超過 20% 才做 VAD）
# VAD_SPEECH_RATIO_SKIP_THRESHOLD=0.80

# --- Google Gemini ---
# 從 https://aistudio.google.com/app/apikey 取得
GOOGLE_API_KEY=your-google-ai-studio-key
