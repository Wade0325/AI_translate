{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Celery Worker",
      "type": "shell",
      "command": "call backend\\.venv\\Scripts\\activate.bat && cd backend && celery -A app.celery.celery:celery_app worker -l INFO -P gevent",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/k"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },
    {
      "label": "FastAPI Server",
      "type": "shell",
      "command": "call backend\\.venv\\Scripts\\activate.bat && cd backend && uvicorn main:app --reload --host 0.0.0.0 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/k"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },
    {
      "label": "React Frontend",
      "type": "shell",
      "command": "cd frontend && npm run dev",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/k"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },
    {
      "label": "🚀 Start All Services",
      "dependsOn": [
        "Celery Worker",
        "FastAPI Server",
        "React Frontend"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "runOptions": {
        "instanceLimit": 1
      }
    }
  ]
}